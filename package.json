{
  "name": "mohamed_portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "format": "prettier --write \"README.md\" \"package.json\" \"jsconfig.json\" \".prettierrc.json\" \".agents/**/*.yml\" \".github/workflows/*.yml\" \"src/architecture/**/*.js\" \"src/env.d.ts\"",
    "format:check": "prettier --check \"README.md\" \"package.json\" \"jsconfig.json\" \".prettierrc.json\" \".agents/**/*.yml\" \".github/workflows/*.yml\" \"src/architecture/**/*.js\" \"src/env.d.ts\"",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p jsconfig.json --noEmit",
    "test": "vitest run",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sweetalert2": "^11.12.4",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
